---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  lang?: 'en' | 'zh';
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="cta-section">
  <div class="cta-container">
    <div class="cta-card">
      <h2 class="cta-title">{t('cta.title')}</h2>
      <a href="#try-free" class="cta-button">
        <span class="btn-arrow">→</span>
        <span class="btn-text">{t('btn.tryFree')}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--section-spacing) 0;
    background-color: var(--color-background);
  }
  
  .cta-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  
  .cta-card {
    background-color: #66D0FF;
    border-radius: 16px;
    padding: 64px 40px;
    text-align: center;
  }
  
  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    color: var(--color-text-dark);
    margin-bottom: 32px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.2;
  }
  
  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: #ffffff;
    color: var(--color-text-dark);
    font-size: 16px;
    font-weight: 500;
    border: none;
    border-radius: 8px;
    transition: all 0.25s ease;
    overflow: hidden;
    position: relative;
  }
  
  .cta-button .btn-arrow {
    display: inline-block;
    width: 0;
    opacity: 0;
    overflow: hidden;
    transition: width 0.25s ease, opacity 0.25s ease, margin 0.25s ease;
    margin-right: 0;
  }
  
  .cta-button:hover .btn-arrow {
    width: 18px;
    opacity: 1;
    margin-right: 4px;
  }
  
  .cta-button:hover {
    background-color: var(--color-text-dark);
    color: #ffffff;
  }
  
  @media (max-width: 768px) {
    .cta-container {
      padding: 0 16px;
    }
    
    .cta-card {
      padding: 48px 24px;
      border-radius: 12px;
    }
    
    .cta-title {
      margin-bottom: 24px;
    }
    
    .cta-button {
      padding: 12px 28px;
      font-size: 15px;
    }
  }
</style>
