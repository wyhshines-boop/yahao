---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const sections = [
    { id: "getting-started", title: "Getting Started" },
    { id: "installation", title: "Installation" },
    { id: "basic-usage", title: "Basic Usage" },
    { id: "translation-settings", title: "Translation Settings" },
    { id: "advanced-features", title: "Advanced Features" },
    { id: "faq", title: "FAQ" },
];
---

<Layout
    title="Documentation - Yahao Translate"
    description="User guide and documentation for Yahao Translate - Learn how to translate your Shopify store"
    lang="en"
>
    <Header currentPage="docs" />
    <main class="docs-page">
        <div class="docs-container">
            <!-- Left Sidebar: Table of Contents -->
            <aside class="docs-sidebar">
                <nav class="docs-toc">
                    <h3 class="toc-heading">On This Page</h3>
                    <ul class="toc-list">
                        {
                            sections.map((section) => (
                                <li>
                                    <a href={`#${section.id}`} class="toc-link">
                                        {section.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>
            </aside>

            <!-- Main Content -->
            <article class="docs-content">
                <header class="docs-header">
                    <h1>Yahao Translate Documentation</h1>
                    <p class="docs-intro">
                        Learn how to use Yahao Translate to automatically
                        translate your Shopify store using AI-powered
                        translations integrated with Shopify's Translate & Adapt
                        app.
                    </p>
                </header>

                <section id="getting-started" class="docs-section">
                    <h2>Getting Started</h2>
                    <p>
                        Yahao Translate is a browser extension that supercharges
                        Shopify's built-in
                        <strong>Translate & Adapt</strong> app with AI-powered translations.
                        Instead of manually translating each product, you can translate
                        your entire store in minutes.
                    </p>
                    <div class="callout callout-info">
                        <strong>Prerequisites:</strong>
                        <ul>
                            <li>
                                A Shopify store with the <a
                                    href="https://apps.shopify.com/translate-and-adapt"
                                    target="_blank">Translate & Adapt</a
                                > app installed
                            </li>
                            <li>Google Chrome or Microsoft Edge browser</li>
                        </ul>
                    </div>
                </section>

                <section id="installation" class="docs-section">
                    <h2>Installation</h2>
                    <h3>Step 1: Install the Extension</h3>
                    <ol>
                        <li>
                            Visit the <a href="#">Chrome Web Store</a> (or Edge Add-ons)
                        </li>
                        <li>Search for "Yahao Translate"</li>
                        <li>Click <strong>Add to Chrome</strong></li>
                        <li>
                            Confirm by clicking <strong>Add extension</strong>
                        </li>
                    </ol>

                    <h3>Step 2: Pin the Extension (Optional)</h3>
                    <p>
                        For quick access, click the puzzle icon in your browser
                        toolbar and pin Yahao Translate.
                    </p>
                </section>

                <section id="basic-usage" class="docs-section">
                    <h2>Basic Usage</h2>
                    <h3>Translating Your Store</h3>
                    <ol>
                        <li>
                            <strong>Open Translate & Adapt:</strong> In your Shopify
                            admin, go to
                            <code>Settings → Languages → Translate & Adapt</code
                            >
                        </li>
                        <li>
                            <strong>Select a Language:</strong> Choose the target
                            language you want to translate to
                        </li>
                        <li>
                            <strong>Click the Translate Button:</strong> Yahao Translate
                            will automatically detect the page and show a floating
                            translate button
                        </li>
                        <li>
                            <strong>Wait for Completion:</strong> The AI will translate
                            all visible content. Progress is shown in real-time
                        </li>
                    </ol>

                    <div class="callout callout-tip">
                        <strong>Tip:</strong> You can translate one resource type
                        at a time (products, collections, pages, etc.) for better
                        organization.
                    </div>
                </section>

                <section id="translation-settings" class="docs-section">
                    <h2>Translation Settings</h2>
                    <p>
                        Click the Yahao Translate icon in your toolbar to access
                        settings:
                    </p>
                    <table class="settings-table">
                        <thead>
                            <tr>
                                <th>Setting</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>AI Model</strong></td>
                                <td
                                    >Choose between different AI providers
                                    (GPT-4, Claude, etc.)</td
                                >
                            </tr>
                            <tr>
                                <td><strong>Translation Style</strong></td>
                                <td>Formal, Casual, or E-commerce optimized</td>
                            </tr>
                            <tr>
                                <td><strong>Auto-save</strong></td>
                                <td
                                    >Automatically save translations after
                                    completion</td
                                >
                            </tr>
                            <tr>
                                <td><strong>Batch Size</strong></td>
                                <td>Number of items to translate at once</td>
                            </tr>
                        </tbody>
                    </table>
                </section>

                <section id="advanced-features" class="docs-section">
                    <h2>Advanced Features</h2>

                    <h3>Glossary / Term Lock</h3>
                    <p>
                        Keep certain terms untranslated (brand names, technical
                        terms):
                    </p>
                    <ol>
                        <li>Open extension settings</li>
                        <li>Go to <strong>Glossary</strong> tab</li>
                        <li>Add terms you want to preserve</li>
                    </ol>

                    <h3>Bulk Translation</h3>
                    <p>
                        Translate multiple pages or entire resource types at
                        once. Navigate to a listing page (e.g., Products list)
                        and click the bulk translate option.
                    </p>

                    <h3>Translation Memory</h3>
                    <p>
                        Previously translated phrases are remembered for
                        consistency. This ensures your product descriptions
                        maintain a uniform voice across your store.
                    </p>
                </section>

                <section id="faq" class="docs-section">
                    <h2>Frequently Asked Questions</h2>

                    <div class="faq-item">
                        <h3>How much does it cost?</h3>
                        <p>
                            Yahao Translate offers a free tier with limited
                            translations per month. Premium plans provide
                            unlimited translations and additional features.
                        </p>
                    </div>

                    <div class="faq-item">
                        <h3>Which languages are supported?</h3>
                        <p>
                            We support all languages available in Shopify's
                            Translate & Adapt app, including Chinese, Spanish,
                            French, German, Japanese, Korean, and 50+ more.
                        </p>
                    </div>

                    <div class="faq-item">
                        <h3>
                            Can I edit translations after they're generated?
                        </h3>
                        <p>
                            Yes! All translations are saved in Shopify's
                            Translate & Adapt app where you can review and edit
                            them at any time.
                        </p>
                    </div>

                    <div class="faq-item">
                        <h3>Is my data secure?</h3>
                        <p>
                            We only access translation content within the
                            Translate & Adapt interface. No store data is stored
                            on our servers. See our <a href="/privacy"
                                >Privacy Policy</a
                            > for details.
                        </p>
                    </div>
                </section>

                <footer class="docs-footer">
                    <p>
                        Still have questions? <a href="/contact"
                            >Contact our support team</a
                        >.
                    </p>
                </footer>
            </article>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    .docs-page {
        background-color: var(--color-background);
        min-height: 100vh;
    }

    .docs-container {
        max-width: var(--page-width);
        margin: 0 auto;
        padding: 60px 24px var(--section-spacing);
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 60px;
        align-items: start;
    }

    /* Sidebar */
    .docs-sidebar {
        position: sticky;
        top: 100px;
    }

    .toc-heading {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-light);
        margin-bottom: 16px;
        font-weight: 600;
    }

    .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
        border-left: 2px solid #e0e0e0;
    }

    .toc-link {
        display: block;
        padding: 10px 0 10px 20px;
        font-size: 14px;
        color: var(--color-text-light);
        border-left: 2px solid transparent;
        margin-left: -2px;
        transition: all 0.2s;
    }

    .toc-link:hover,
    .toc-link.active {
        color: var(--color-primary);
        border-left-color: var(--color-primary);
    }

    /* Content */
    .docs-content {
        max-width: 800px;
    }

    .docs-header {
        margin-bottom: 48px;
        padding-bottom: 32px;
        border-bottom: 1px solid #eee;
    }

    .docs-header h1 {
        font-family: "Zilla Slab", serif;
        font-size: clamp(32px, 5vw, 42px);
        font-weight: 500;
        margin-bottom: 16px;
        color: var(--color-text-dark);
    }

    .docs-intro {
        font-size: 18px;
        line-height: 1.7;
        color: var(--color-text-light);
    }

    .docs-section {
        margin-bottom: 56px;
        scroll-margin-top: 100px;
    }

    .docs-section h2 {
        font-family: "Zilla Slab", serif;
        font-size: 28px;
        font-weight: 500;
        margin-bottom: 20px;
        color: var(--color-text-dark);
        padding-bottom: 12px;
        border-bottom: 1px solid #eee;
    }

    .docs-section h3 {
        font-size: 20px;
        font-weight: 600;
        margin: 32px 0 16px;
        color: var(--color-text-dark);
    }

    .docs-section p {
        font-size: 16px;
        line-height: 1.8;
        margin-bottom: 16px;
        color: var(--color-text-dark);
    }

    .docs-section ol,
    .docs-section ul {
        padding-left: 24px;
        margin-bottom: 20px;
    }

    .docs-section li {
        font-size: 16px;
        line-height: 1.8;
        margin-bottom: 8px;
    }

    .docs-section a {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .docs-section code {
        background-color: #f0f4f8;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 14px;
        font-family: "SF Mono", Monaco, monospace;
    }

    /* Callouts */
    .callout {
        padding: 20px 24px;
        border-radius: 8px;
        margin: 24px 0;
    }

    .callout-info {
        background-color: #e8f4fd;
        border-left: 4px solid var(--color-primary);
    }

    .callout-tip {
        background-color: #e6f7ed;
        border-left: 4px solid #10b981;
    }

    .callout ul {
        margin-bottom: 0;
        margin-top: 12px;
    }

    /* Table */
    .settings-table {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
    }

    .settings-table th,
    .settings-table td {
        text-align: left;
        padding: 14px 16px;
        border-bottom: 1px solid #eee;
    }

    .settings-table th {
        background-color: #f8f9fa;
        font-weight: 600;
        font-size: 14px;
    }

    .settings-table td {
        font-size: 15px;
    }

    /* FAQ */
    .faq-item {
        margin-bottom: 28px;
    }

    .faq-item h3 {
        margin-top: 0;
        margin-bottom: 8px;
    }

    .faq-item p {
        margin-bottom: 0;
    }

    /* Footer */
    .docs-footer {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid #eee;
    }

    .docs-footer p {
        color: var(--color-text-light);
    }

    /* Mobile */
    @media (max-width: 1024px) {
        .docs-container {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .docs-sidebar {
            position: static;
            border-bottom: 1px solid #eee;
            padding-bottom: 24px;
        }

        .toc-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            border-left: none;
        }

        .toc-link {
            border-left: none;
            border: 1px solid #e0e0e0;
            border-radius: 20px;
            padding: 8px 16px;
            margin-left: 0;
        }

        .toc-link:hover,
        .toc-link.active {
            border-color: var(--color-primary);
            background-color: #e8f4fd;
        }
    }

    @media (max-width: 768px) {
        .docs-container {
            padding: 40px 16px;
        }

        .docs-header h1 {
            font-size: 28px;
        }

        .docs-section h2 {
            font-size: 24px;
        }
    }
</style>

<script>
    // Highlight active TOC link on scroll
    const sections = document.querySelectorAll(".docs-section");
    const tocLinks = document.querySelectorAll(".toc-link");

    function updateActiveLink() {
        let currentSection = "";

        sections.forEach((section) => {
            const sectionTop = section.getBoundingClientRect().top;
            if (sectionTop < 150) {
                currentSection = section.getAttribute("id") || "";
            }
        });

        tocLinks.forEach((link) => {
            link.classList.remove("active");
            if (link.getAttribute("href") === `#${currentSection}`) {
                link.classList.add("active");
            }
        });
    }

    window.addEventListener("scroll", updateActiveLink);
    updateActiveLink();
</script>
