---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import SubscriptionToggle from "../../components/SubscriptionToggle.astro";
import { useTranslations } from "../../i18n/utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  // Filter out Chinese posts (they have slugs starting with "zh/")
  const englishPosts = posts.filter((post) => !post.slug.startsWith("zh/"));
  return englishPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const t = useTranslations("en");

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  currentPage="blog"
  title={post.data.metaTitle || `${post.data.title} - Yahao Translate Blog`}
  description={post.data.metaDescription || post.data.excerpt}
  image={post.data.image?.src}
  lang="en"
>
  <Header currentPage="blog" />
  <main>
    <article class="blog-page">
      <div class="blog-container">
        <!-- Left Column: Content -->
        <div class="blog-main">
          <header class="article-header">
            <h1 class="article-title">{post.data.title}</h1>
            <p class="article-excerpt">{post.data.excerpt}</p>
            <div class="article-meta">
              <span class="article-author">{post.data.author}</span>
              <span class="meta-separator">•</span>
              <span class="article-date">{formatDate(post.data.date)}</span>
            </div>
          </header>

          {
            post.data.image && (
              <div class="featured-image-wrapper">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  class="featured-image"
                />
              </div>
            )
          }

          <div class="article-content">
            <Content />
          </div>

          <footer class="article-footer">
            <a href="/blog" class="back-link">← Back to Blog</a>
          </footer>
        </div>

        <!-- Right Column: Sidebar -->
        <aside class="blog-sidebar">
          <div class="sticky-wrapper">
            {
              headings.length > 0 && (
                <nav class="toc">
                  <h3 class="toc-title">Table of Contents</h3>
                  <ul class="toc-list">
                    {headings
                      .filter((h) => h.depth <= 3)
                      .map((h) => (
                        <li class={`toc-item depth-${h.depth}`}>
                          <a href={`#${h.slug}`}>{h.text}</a>
                        </li>
                      ))}
                  </ul>
                </nav>
              )
            }

            <div class="sidebar-promos">
              <div class="sidebar-cta">
                <h3 class="cta-heading">{t("cta.title")}</h3>

                <a href="#try-free" class="btn-primary sidebar-btn">
                  <span class="btn-arrow">→</span>
                  <span class="btn-text">{t("btn.tryFree")}</span>
                </a>
              </div>

              <div class="sidebar-subscription">
                <SubscriptionToggle />
              </div>
            </div>
          </div>
        </aside>
      </div>
    </article>
  </main>
</Layout>
<Footer />

<style>
  .blog-page {
    --font-heading: var(--font-body);
    padding: 60px 0 var(--section-spacing);
    background-color: var(--color-background);
  }

  .blog-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 60px;
    align-items: start;
  }

  /* Left Column */
  .blog-main {
    min-width: 0; /* Prevents overflow in grid */
  }

  .article-header {
    margin-bottom: 32px;
  }

  .article-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    color: var(--color-text-dark);
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .article-excerpt {
    font-size: 20px;
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 24px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--color-text-light);
  }

  .article-author {
    font-weight: 500;
    color: var(--color-text-dark);
  }

  .featured-image-wrapper {
    margin-bottom: 40px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: none;
  }

  .featured-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-content {
    font-size: 17px;
    line-height: 1.8;
    color: var(--color-text-dark);
  }

  /* Typography for Content */
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3) {
    font-family: var(--font-heading);
    color: var(--color-text-dark);
    scroll-margin-top: 100px; /* Offset for sticky header */
  }

  .article-content :global(h1) {
    font-size: 32px;
    margin: 48px 0 24px;
  }
  .article-content :global(h2) {
    font-size: 26px;
    margin: 40px 0 20px;
    font-weight: 600;
  }
  .article-content :global(h3) {
    font-size: 22px;
    margin: 32px 0 16px;
    font-weight: 600;
  }

  .article-content :global(p) {
    margin-bottom: 20px;
  }
  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .article-content :global(li) {
    margin-bottom: 8px;
  }

  .article-content :global(strong) {
    font-weight: 600;
  }
  .article-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid #eee;
    margin: 40px 0;
  }
  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 24px 0;
  }
  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding-left: 20px;
    margin: 24px 0;
    font-style: italic;
    color: var(--color-text-light);
  }

  .article-footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid #eee;
  }

  .back-link {
    font-size: 15px;
    color: var(--color-text-dark);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  /* Right Sidebar */
  .blog-sidebar {
    height: 100%;
  }

  .sticky-wrapper {
    position: sticky;
    top: 100px; /* Header height + spacing */
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* TOC */
  .toc-title {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid #f0f0f0;
  }

  .toc-item {
    margin-bottom: 0;
  }

  .toc-item a {
    display: block;
    padding: 8px 0 8px 20px;
    font-size: 14px;
    color: var(--color-text-light);
    text-decoration: none;
    transition: all 0.2s;
    border-left: 2px solid transparent;
    margin-left: -2px;
  }

  .toc-item a:hover {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  .toc-item.depth-3 a {
    padding-left: 36px;
    font-size: 13px;
  }

  /* Sidebar CTA */
  .sidebar-cta {
    background-color: #e3f1ff;
    padding: 24px;
    border-radius: 12px;
    border: none;
    display: flex;
    flex-direction: column;
    gap: 24px; /* Force gap between title and button */
  }

  .cta-heading {
    font-size: 20px;
    font-weight: 500;
    color: var(--color-text-dark);
    margin-bottom: 0; /* Remove margin, use gap */
    line-height: 1.4;
    font-family: "Zilla Slab", serif !important; /* Force serif */
  }

  .cta-text {
    font-size: 14px;
    color: var(--color-text-light);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .sidebar-btn {
    width: 100%;
  }

  .sidebar-promos {
    display: flex;
    flex-direction: column;
    gap: 16px; /* Closer gap between CTA and Subscription */
  }

  .sidebar-subscription {
    margin-top: 0;
  }

  @media (max-width: 1024px) {
    .blog-container {
      grid-template-columns: 1fr; /* Stack on tablet/mobile */
      max-width: 720px; /* Constrain width when stacked */
      gap: 48px;
    }

    .blog-sidebar {
      order: 2; /* Sidebar below content */
      border-top: 1px solid #eee;
      padding-top: 48px;
    }

    .sticky-wrapper {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .blog-page {
      padding: 40px 0 var(--section-spacing);
    }

    .article-container {
      /* Unused class in new layout, can remove or refactor */
      padding: 0 16px;
    }

    .article-title {
      font-size: 28px;
    }
  }
</style>
