---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout currentPage="contact">
  <Header currentPage="contact" />
  <main>
    <section class="contact-hero">
      <div class="contact-container">
        <p class="contact-subtitle">Get in Touch</p>
        <h1 class="contact-title">CONTACT</h1>
      </div>
    </section>
    
    <section class="contact-content">
      <div class="contact-container">
        <div class="contact-grid">
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 6C22 4.9 21.1 4 20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6ZM20 6L12 11L4 6H20ZM20 18H4V8L12 13L20 8V18Z" fill="currentColor"/>
              </svg>
            </div>
            <h2 class="contact-label">Email</h2>
            <a href="mailto:support@yahaotranslate.com" class="contact-value">support@yahaotranslate.com</a>
            <p class="contact-description">We typically respond within 24 hours.</p>
          </div>
          
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" fill="currentColor"/>
              </svg>
            </div>
            <h2 class="contact-label">WhatsApp</h2>
            <a href="https://wa.me/8617633975260" target="_blank" rel="noopener" class="contact-value">+86 176 3397 5260</a>
            <p class="contact-description">Available for quick questions and support.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .contact-hero {
    padding: 60px 0 40px;
    background-color: var(--color-background);
  }
  
  .contact-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  
  .contact-subtitle {
    font-size: 16px;
    color: var(--color-text-dark);
    margin-bottom: 8px;
  }
  
  .contact-title {
    font-family: var(--font-heading);
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 400;
    color: var(--color-text-dark);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  
  .contact-content {
    padding: 40px 0 var(--section-spacing);
    background-color: var(--color-background);
  }
  
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
    max-width: 800px;
  }
  
  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .contact-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dark);
  }
  
  .contact-label {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    color: var(--color-text-dark);
  }
  
  .contact-value {
    font-size: 18px;
    color: var(--color-text-dark);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  
  .contact-value:hover {
    color: var(--color-primary);
  }
  
  .contact-description {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.5;
  }
  
  @media (max-width: 768px) {
    .contact-hero {
      padding: 40px 0 24px;
    }
    
    .contact-container {
      padding: 0 16px;
    }
    
    .contact-subtitle {
      font-size: 14px;
    }
    
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .contact-label {
      font-size: 20px;
    }
    
    .contact-value {
      font-size: 16px;
    }
  }
</style>
